module sipo_tb;

reg clk, rst, d;
wire [0:3] q;

sipo uut (
    .clk(clk),
    .rst(rst),
    .d(d),
    .q(q)
);


initial begin
    clk = 0;
    forever #5 clk = ~clk;
end


initial begin

    d = 0;
    rst = 0;
    
  
      
	#20 rst = 1; 
	#10 d = 1;
    	#10 d = 0;  
    
    	#10 d = 0;  
    	#10 d = 1;  
    	#10 d = 1;  
    	#10 d = 0;  
	#10 d = 1;  
    	#10 d = 1;  

    	#1 $stop;
end

endmodule

