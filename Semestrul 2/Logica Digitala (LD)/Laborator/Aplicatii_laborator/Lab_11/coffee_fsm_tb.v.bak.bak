module coffee_fsm_tb;

    localparam CLK_PERIOD = 10; 
    
    reg clk = 0;
    reg rst = 1; 
    reg credit5, credit10;
    reg [1:0] cofee;
    wire [2:0] current_state;
    wire exprr, expr_1, capp;
    
    coffee_fsm dut (
        .clk(clk),
        .rst(rst),
        .credit5(credit5),
        .credit10(credit10),
        .cofee(cofee),
        .current_state(current_state),
        .exprr(exprr),
        .expr_1(expr_1),
        .capp(capp)
    );     
    initial begin
        
        #CLK_PERIOD * 5;
        
        rst = 0;
        
        
        // Test 1: credit5 activat
        credit5 = 1;
        credit10 = 0;
        cofee = 2'b00; e
        #CLK_PERIOD * 5; 
        
        // Test 2: credit10 activat
        credit5 = 0;
        credit10 = 1;
        cofee = 2'b00;
        #CLK_PERIOD * 5;
        
        // Test 3: ambii credite activate, cofee diferit
        credit5 = 1;
        credit10 = 1;
        cofee = 2'b01;
        #CLK_PERIOD * 5;
        
        $finish;
    end
    
endmodule

